# BiblioDrift Environment Configuration Example
# Copy this file to .env and customize for your environment

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
APP_ENV=development

# =============================================================================
# REQUIRED: JWT & SECURITY CONFIGURATION
# =============================================================================
# CRITICAL: Must be set before app startup. Generate a secure key in production.
JWT_SECRET_KEY=your-super-secret-jwt-key-here-min-32-chars
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
JWT_ALGORITHM=HS256

# =============================================================================
# REQUIRED: DATABASE CONFIGURATION
# =============================================================================
# CRITICAL: Must be set before app startup.
DATABASE_URL=sqlite:///instance/biblio.db
SQLALCHEMY_TRACK_MODIFICATIONS=False


# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
FLASK_HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=False

# =============================================================================
# REQUIRED: API KEYS & EXTERNAL SERVICES
# =============================================================================
# CRITICAL: GOOGLE_BOOKS_API_KEY must be set before app startup.
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Optional AI Service Keys
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
GEMINI_API_KEY=your-gemini-api-key

# Email Service Configuration
EMAIL_SERVICE=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@bibliodrift.com

# External Storage Configuration
STORAGE_ACCESS_KEY=your-storage-access-key
STORAGE_SECRET_KEY=your-storage-secret-key
STORAGE_BUCKET=bibliodrift-assets
STORAGE_REGION=us-east-1


# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
CACHE_TYPE=simple
REDIS_URL=redis://localhost:6379/0

# Cache TTL Values (in seconds)
CACHE_MOOD_ANALYSIS_TTL=86400
CACHE_RECOMMENDATIONS_TTL=3600
CACHE_MOOD_TAGS_TTL=43200
CACHE_CHAT_RESPONSE_TTL=1800
CACHE_GOODREADS_TTL=604800
CACHE_DEFAULT_TIMEOUT=3600

# Redis Memory Management & Eviction
# Prevents OOM by defining how Redis should behave when it reaches memory limits
REDIS_MAXMEMORY=512mb
REDIS_EVICTION_POLICY=allkeys-lru

# LLM Configuration
PREFERRED_LLM=groq
OPENAI_MODEL=gpt-3.5-turbo
GROQ_MODEL=openai/gpt-oss-20b
GEMINI_MODEL=gemini-1.5-flash
DEFAULT_MAX_TOKENS=150
BOOK_NOTE_MAX_TOKENS=100
RECOMMENDATION_MAX_TOKENS=150

# Purchase Links Configuration
AMAZON_AFFILIATE_TAG=your_amazon_affiliate_tag
FLIPKART_AFFILIATE_ID=your_flipkart_affiliate_id
BARNES_NOBLE_AFFILIATE_ID=your_barnes_noble_affiliate_id
PURCHASE_LINKS_CACHE_TTL=3600

# Caching Configuration (if using caching features)
# CACHE_TYPE=simple
# REDIS_URL=redis://localhost:6379/0
# CACHE_MOOD_ANALYSIS_TTL=86400
# CACHE_RECOMMENDATIONS_TTL=3600
# CACHE_MOOD_TAGS_TTL=43200
# CACHE_CHAT_RESPONSE_TTL=1800
# CACHE_GOODREADS_TTL=604800
# CACHE_DEFAULT_TIMEOUT=3600
PURCHASE_LINKS_TIMEOUT=10
PURCHASE_LINKS_MAX_RETRIES=3
PURCHASE_LINKS_RETRY_DELAY=1.0
PURCHASE_LINKS_MAX_CONCURRENT=4
PURCHASE_LINKS_LOG_LEVEL=INFO

# =============================================================================
# BiliBili Authentication (API testing / local integrations)
# =============================================================================
phone=your_phone_number
pwd=your_password
mid=your_mid_value
buvid=your_buvid_value
csrf=your_csrf_token

# BiliBili API Credentials
appKey=your_app_key_here
access_key=your_access_key_here

# Session Data
cookieStr=your_cookie_string_here
bili_ticket=your_jwt_token_here
