# Development Environment Configuration

# Application Environment
APP_ENV=development

# JWT Configuration
JWT_SECRET_KEY=bibliodrift_super_secret_dev_key_2024_99!@#
JWT_ACCESS_TOKEN_EXPIRES_DAYS=7
JWT_ALGORITHM=HS256

# Database Configuration
DATABASE_URL=sqlite:///biblio.db
SQLALCHEMY_TRACK_MODIFICATIONS=False

# Server Configuration
FLASK_HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=True
ALLOWED_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5000,http://localhost:5000

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=True
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=30

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
# LOG_FILE=logs/bibliodrift-dev.log

# AI Service Configuration
# OPENAI_API_KEY=your-openai-api-key
# GROQ_API_KEY=your-groq-key-here
GEMINI_API_KEY=AIzaSyA6Qhdu5SGramUh1d7GbsKViQrZz7cTtog
# GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Elara persona config
# Use groq for dev (free, unlimited) — switch to gemini in prod
PREFERRED_LLM=gemini
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MAX_TOKENS=600
GROQ_TEMPERATURE=0.85
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=1200
GEMINI_TEMPERATURE=0.85